# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/jpg

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username

# Admin Credentials (seed)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@stroymarket.uz
ADMIN_PHONE=+998901234567
ADMIN_PASSWORD=Admin@12345

# Seller Credentials (seed)
SELLER_NAME=Toshkent Qurilish
SELLER_EMAIL=seller@stroymarket.uz
SELLER_PHONE=+998901234568
SELLER_PASSWORD=Seller@12345

# Client Credentials (seed)
CLIENT_NAME=Abdullayev Jasur
CLIENT_EMAIL=client@stroymarket.uz
CLIENT_PHONE=+998901234569
CLIENT_PASSWORD=Client@12345

# App URL
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Subscription Prices (UZS)
SUBSCRIPTION_BASIC_PRICE=100000
SUBSCRIPTION_SILVER_PRICE=200000
SUBSCRIPTION_GOLD_PRICE=300000
